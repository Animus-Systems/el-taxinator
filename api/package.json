{
  "name": "taxinator-api",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "description": "tRPC + OpenAPI API for Taxinator (App DB + Identity DB)",
  "scripts": {
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.json --watch",
    "build": "yarn generate:types && tsc -p tsconfig.json",
    "generate:types": "tsx src/scripts/generateUiTypes.ts",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "dbctl": "tsx ../database/bin/dbctl.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^6.4.0",
    "@simplewebauthn/server": "^10.0.1",
    "@trpc/server": "^10.45.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "otplib": "^12.0.1",
    "pg": "^8.11.5",
    "swagger-ui-express": "^5.0.0",
    "trpc-openapi": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.6",
    "openapi-typescript": "^7.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
