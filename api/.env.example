# --- Server -----------------------------------------------------------------
PORT=4000
NODE_ENV=development
TRUST_PROXY_HOPS=1
BASE_URL=http://localhost:4000
PUBLIC_ORIGIN=http://localhost:4000

# CORS allowlist (comma-separated). UI repo origin should land here in prod.
CORS_ALLOWED_DOMAINS=
DOCS_ENABLED=true

# --- Auth -------------------------------------------------------------------
# Required in production. In dev a deterministic fallback is used.
JWT_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Cookie hardening (production: COOKIE_SECURE=true + COOKIE_SAMESITE=None).
COOKIE_SECURE=
COOKIE_SAMESITE=
COOKIE_NAME_REFRESH=
COOKIE_NAME_CSRF=

# Print verification codes / refresh tokens in API responses (dev only).
AUTH_EXPOSE_DEV_CODES=true

# Internal API key for service-to-service calls (workers). Optional.
INTERNAL_API_KEY=

# --- Tenants ----------------------------------------------------------------
# Roles in core.tenant_member that count as admins.
TENANT_ADMIN_ROLES=owner,admin
# Comma-separated emails granted platform-admin powers (read-only auditing, etc).
PLATFORM_ADMIN_EMAILS=

# --- Databases --------------------------------------------------------------
APP_DB_URL=postgresql://app_api_login:devpassword@localhost:5432/app_db
IDENTITY_DB_URL=postgresql://identity_app:devpassword@localhost:5432/identity_db
# Admin connections used by migrations / break-glass operations.
APP_DB_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/app_db
IDENTITY_DB_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/identity_db
APP_DB_SSL=false
IDENTITY_DB_SSL=false
DB_SSL_INSECURE=false
DB_SSL_CA_FILE=

# --- File uploads (v1: on-disk) --------------------------------------------
UPLOAD_DIR=./data/uploads

# --- OAuth providers (optional) ---------------------------------------------
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=

# --- Passkeys / WebAuthn ----------------------------------------------------
PASSKEY_RP_ID=
PASSKEY_RP_NAME=Taxinator
PASSKEY_EXPECTED_ORIGINS=http://localhost:4000

# --- dbctl dev helpers ------------------------------------------------------
DBCTL_DEV_PASSWORD=devpassword
