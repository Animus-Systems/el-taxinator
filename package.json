  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"yarn dev:server\" \"yarn dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx --tsconfig server/tsconfig.json server/index.ts",
    "dev:server:watch": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "build": "vite build",
    "start": "node --import tsx server/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
