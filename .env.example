PORT=7331
SELF_HOSTED_MODE=true

# Auth (required — generate a random string, min 16 chars)
BETTER_AUTH_SECRET="change-me-to-a-random-secret"

# LLM providers (configure at least one for AI features, or set via the app UI)
OPENAI_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY=""

GOOGLE_MODEL_NAME="gemini-2.5-flash"
GOOGLE_API_KEY=""

MISTRAL_MODEL_NAME="mistral-medium-latest"
MISTRAL_API_KEY=""

ANTHROPIC_MODEL_NAME="claude-sonnet-4-6"
ANTHROPIC_API_KEY=""

# Optional: OpenRouter or custom OpenAI-compatible endpoint
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL_NAME="anthropic/claude-sonnet-4"
# CUSTOM_LLM_BASE_URL=""
# CUSTOM_LLM_API_KEY=""
# CUSTOM_LLM_MODEL_NAME=""

# Optional: Google Drive auto-backup
# GOOGLE_DRIVE_CLIENT_ID=""
# GOOGLE_DRIVE_CLIENT_SECRET=""

# Optional: Cron backup security token
# CRON_SECRET=""

# Optional: Stripe billing (cloud mode only)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Optional: Email via Resend
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="Taxinator <user@localhost>"
# RESEND_AUDIENCE_ID=""
